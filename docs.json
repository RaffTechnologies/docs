{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Raff Cloud Platform",
  "colors": {
    "primary": "#6366F1",
    "light": "#818CF8",
    "dark": "#4F46E5"
  },
  "favicon": "/favicon.ico",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "api": {
    "baseUrl": "https://api.rafftechnologies.com",
    "auth": {
      "method": "key",
      "name": "X-API-Key"
    },
    "playground": {
      "mode": "simple"
    }
  },
  "openapi": ["/api-reference/openapi.yaml"],
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "introduction",
              "quickstart",
              "authentication"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/create-your-first-vm"
            ]
          }
        ]
      },
      {
        "tab": "Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "reference/introduction"
            ]
          },
          {
            "group": "APIs",
            "pages": [
              "api-reference/introduction",
              {
                "group": "Virtual Machines",
                "pages": [
                  "api-reference/endpoint/list-vms",
                  "api-reference/endpoint/create-vm",
                  "api-reference/endpoint/get-vm",
                  "api-reference/endpoint/delete-vm",
                  "api-reference/endpoint/start-vm",
                  "api-reference/endpoint/stop-vm",
                  "api-reference/endpoint/reboot-vm",
                  "api-reference/endpoint/resize-vm"
                ]
              },
              {
                "group": "Volumes",
                "pages": ["api-reference/volumes/introduction"]
              },
              {
                "group": "Snapshots",
                "pages": ["api-reference/snapshots/introduction"]
              },
              {
                "group": "Backups",
                "pages": ["api-reference/backups/introduction"]
              }
            ]
          },
          {
            "group": "CLI",
            "pages": [
              "reference/cli/introduction"
            ]
          },
          {
            "group": "Terraform",
            "pages": [
              "reference/terraform/introduction"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Dashboard",
          "href": "https://app.rafftechnologies.com",
          "icon": "gauge"
        },
        {
          "anchor": "Support",
          "href": "mailto:support@rafftechnologies.com",
          "icon": "envelope"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@rafftechnologies.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://app.rafftechnologies.com"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/rafftechnologies",
      "github": "https://github.com/rafftechnologies",
      "linkedin": "https://linkedin.com/company/rafftechnologies"
    }
  }
}
